{
  "expo": {
    "name": "Reflow",
    "slug": "reflow",
    "scheme": "reflow",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.senul.reflow"
    },
    "android": {
      "package": "com.senul.reflow",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-status-bar",
      "expo-updates",
      "expo-web-browser",
      "expo-sharing",
      "expo-secure-store",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "Reflow uses the microphone so you can speak your reflections instead of typing them."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Reflow lets you attach photos of past papers and notes to your study log.",
          "cameraPermission": "Reflow lets you snap a past paper or worked solution to attach to your study log."
        }
      ],
      [
        "expo-image",
        {
          "photosPermission": "Reflow can save study images to your library."
        }
      ],
      "expo-asset"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e3ec5c8-fdd2-4954-8677-8793e10e2f75",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e3ec5c8-fdd2-4954-8677-8793e10e2f75"
      }
    },
    "owner": "senulmapa"
  }
}
