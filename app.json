{
  "expo": {
    "name": "Reflow",
    "slug": "reflow",
    "scheme": "reflow",
    "version": "2.2.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.senul.reflow"
    },
    "android": {
      "package": "com.senul.reflow",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/IBMPlexMono-Regular.ttf",
            "./assets/fonts/IBMPlexMono-SemiBold.ttf",
            "./assets/fonts/DotGothic16-Regular.ttf",
            "./assets/fonts/Newsreader-Italic.ttf"
          ]
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e3ec5c8-fdd2-4954-8677-8793e10e2f75",
      "channel": "production",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e3ec5c8-fdd2-4954-8677-8793e10e2f75"
      }
    },
    "owner": "senulmapa"
  }
}
